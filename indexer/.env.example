# ---- Chain selection ---------------------------------------------------------
# 1 = mainnet, 11155111 = sepolia (default)
CHAIN_ID=11155111

# RPC endpoints (Ponder convention: PONDER_RPC_URL_<chainId>)
PONDER_RPC_URL_1=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
PONDER_RPC_URL_11155111=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# ---- Database ----------------------------------------------------------------
# Postgres connection string (Neon / Supabase / local).
# Leave unset to use Ponder's embedded PGlite in local dev.
DATABASE_URL=postgresql://user:password@host:5432/hoodiepad

# ---- HOODIEPAD contract addresses + deploy blocks ----------------------------
# Contracts are being deployed in parallel — fill these in once live.
LAUNCHER_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
LAUNCHER_REGISTRY_START_BLOCK=0

TOKEN_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
TOKEN_FACTORY_START_BLOCK=0

BONDING_CURVE_ADDRESS=0x0000000000000000000000000000000000000000
BONDING_CURVE_START_BLOCK=0

GRADUATION_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000
GRADUATION_MANAGER_START_BLOCK=0

# ---- Stubbed services --------------------------------------------------------
# Pinata JWT for IPFS metadata pinning (see src/pin.ts — currently stubbed).
PINATA_JWT=
