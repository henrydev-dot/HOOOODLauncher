# WalletConnect Cloud project id (falls back to "demo")
NEXT_PUBLIC_WC_PROJECT_ID=demo

# Chain: 4663 (Robinhood Chain — default), 46630 (Robinhood Chain Testnet),
#        1 (Ethereum mainnet), 11155111 (Sepolia)
NEXT_PUBLIC_CHAIN_ID=4663

# Optional RPC override for Robinhood Chain (defaults per chain)
NEXT_PUBLIC_RPC_URL=

# Contract addresses. Leave REGISTRY zeroed to run in demo mode (mock data +
# simulated wallet flows).
NEXT_PUBLIC_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_CURVE_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_GRADUATION_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_FEESPLITTER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_HOODIE_ADDRESS=0xC72c01AAB5f5678dc1d6f5C6d2B417d91D402Ba3

# Indexer REST API base url. Empty => built-in deterministic mock data.
NEXT_PUBLIC_API_URL=

# $HOODIE links on the home page (defaults: DexScreener search by address)
NEXT_PUBLIC_HOODIE_DEXSCREENER_URL=
NEXT_PUBLIC_HOODIE_BUY_URL=
